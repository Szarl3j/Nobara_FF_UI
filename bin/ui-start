#!/bin/bash

PROJECT_DIR="$HOME/Nobara_FF_UI"

pkill waybar 2>/dev/null
pkill mpvpaper 2>/dev/null
pkill -f notification_listener.py 2>/dev/null

export PATH="$PROJECT_DIR/bin:$PATH"

"$PROJECT_DIR/bin/wallpaper" &
"$PROJECT_DIR/bin/play-sound" "Duty Pop" &

python3 "$PROJECT_DIR/modules/alliance/alliance_a_discord/notification_listener.py" &

waybar -c "$PROJECT_DIR/waybar/config.jsonc" -s "$PROJECT_DIR/waybar/style.css" &