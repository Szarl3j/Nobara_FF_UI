#!/bin/bash

PROJECT_DIR="$HOME/Nobara_FF_UI"
SOUND_NAME="$*"

RINGTONE="$PROJECT_DIR/assets/sounds/ringtones/$SOUND_NAME.mp3"
SOUND="$PROJECT_DIR/assets/sounds/$SOUND_NAME.mp3"

if [ -f "$RINGTONE" ]; then
    mpv --no-video --really-quiet "$RINGTONE" &
    exit 0
fi

if [ -f "$SOUND" ]; then
    mpv --no-video --really-quiet "$SOUND" &
    exit 0
fi

exit 1